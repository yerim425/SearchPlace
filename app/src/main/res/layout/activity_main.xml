<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <import type="android.view.View" />
        <variable
            name="vm"
            type="com.yrlee.tpsearchplaceapp.viewmodel.MainViewModel" />
    </data>

    <FrameLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <!-- 화면 내용 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/pink"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/app_logo"/>

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="?android:attr/actionBarSize"
                    android:layout_weight="1"
                    android:hint="@string/enter_search_terms"
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:layout_marginHorizontal="8dp"
                    android:text="@={vm.searchQuery}" />

                <ImageView
                    android:id="@+id/iv_refresh"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:onClick="@{()->vm.searchPlaces()}"
                    android:src="@drawable/baseline_refresh_24"
                    android:layout_gravity="bottom"
                    android:layout_marginBottom="4dp"
                    app:tint="#3d3d3d" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/toolbar"
                android:background="@color/pink"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:text="반가워요, 원하는 장소를 검색해 보세요."
                android:textColor="@color/black" />
            <!-- 단축 검색 아이콘 버튼들 -->
            <HorizontalScrollView
                android:id="@+id/scroll_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_title"
                android:background="@color/pink"
                android:padding="4dp"
                android:scrollbars="none">

                <include
                    android:id="@+id/choice_layout"
                    layout="@layout/choice_list" />
            </HorizontalScrollView>

            <!-- 프래그먼트들이 놓여질 뷰 그룹 -->
            <!--            <FrameLayout-->
            <!--                android:id="@+id/fragment_container"-->
            <!--                android:layout_width="match_parent"-->
            <!--                android:layout_height="match_parent"-->
            <!--                android:layout_below="@id/scroll_view" />-->
            <TextView
                android:id="@+id/tv_cnt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/scroll_view"
                android:layout_alignParentEnd="true"
                android:paddingTop="8dp"
                android:paddingEnd="8dp"
                android:text="@{vm.count}"
                android:textColor="@color/gray"
                android:textSize="12sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_below="@id/tv_cnt"
                android:orientation="vertical"
                android:padding="8dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />


        </RelativeLayout>

        <LinearLayout
            android:id="@+id/fabContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="bottom|center"
            android:layout_gravity="bottom|end">

            <!-- 좋아요 목록 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabFavorite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:contentDescription="@string/favorite_list"
                app:srcCompat="@drawable/baseline_favorite_24"
                app:backgroundTint="@color/blue"
                app:shapeAppearanceOverlay="@style/FabCircle"/>


            <!-- 지도 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabMap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginTop="6dp"
                android:contentDescription="@string/map"
                app:srcCompat="@drawable/ic_map"
                app:backgroundTint="@color/blue"
                app:shapeAppearanceOverlay="@style/FabCircle"/>


            <!-- 메인 버튼 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton                android:id="@+id/fabMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:srcCompat="@drawable/ic_add"
                app:backgroundTint="@color/blue"
                android:layout_marginTop="6dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="24dp"
                app:shapeAppearanceOverlay="@style/FabCircle"/>


        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/pink_dark"
            android:visibility="@{vm.loading ? View.VISIBLE : View.GONE}" />
    </FrameLayout>
